# ─────────────────────────────────────────────────────────────────────────────
# KINŌ — Environment Variables
# Copy this file to .env.local and fill in your values.
# Register your Strava app at: https://www.strava.com/settings/api
# ─────────────────────────────────────────────────────────────────────────────

# Your Strava Application Client ID (public — safe to expose)
VITE_STRAVA_CLIENT_ID=YOUR_CLIENT_ID_HERE

# Your Strava Application Client Secret
# ⚠️  For production, proxy token exchange through a backend so this stays server-side.
# For the MVP web app it lives here — do NOT commit .env.local to git.
VITE_STRAVA_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# The URL Strava redirects to after OAuth.
# Must match exactly what you set in your Strava app settings.
VITE_STRAVA_REDIRECT_URI=http://localhost:3000/callback

# Strava API base URL (rarely changes)
VITE_STRAVA_API_BASE=https://www.strava.com/api/v3
